# ─────────────────────────────────────────────
#  Pet Licence Factory — Environment Variables
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Xano
XANO_API_BASE_URL=https://your-instance.xano.io/api:xxxxxxxx
XANO_API_KEY=

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=orders@yourstore.com
SENDGRID_FROM_NAME=Pet Licence Factory

# Shippo
SHIPPO_API_KEY=shippo_live_...
SHIPPO_FROM_NAME=Pet Licence Factory
SHIPPO_FROM_STREET=
SHIPPO_FROM_CITY=
SHIPPO_FROM_STATE=
SHIPPO_FROM_ZIP=
SHIPPO_FROM_COUNTRY=US
