# ─────────────────────────────────────────────
#  Pet Licence Factory — Environment Variables
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Database (AWS RDS Postgres — shared instance)
DATABASE_URL=postgresql://plf_admin:PASSWORD@lessoncomplete-db.c9e2648w8z0z.us-east-2.rds.amazonaws.com:5432/petlicencefactory?sslmode=require

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin API authentication
ADMIN_PASSWORD_HASH=          # bcrypt hash of admin password (generate with: node -e "console.log(require('bcryptjs').hashSync('your-password',12))")
ADMIN_JWT_SECRET=             # random 64-char hex string (generate with: openssl rand -hex 32)

# EasyPost (shipping labels + tracking)
EASYPOST_API_KEY=

# SendGrid (transactional emails)
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=orders@yourstore.com
SENDGRID_FROM_NAME=Pet Licence Factory
